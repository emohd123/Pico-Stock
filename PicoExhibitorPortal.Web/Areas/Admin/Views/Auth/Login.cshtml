@model PicoExhibitorPortal.Web.Models.Admin.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin login";
}

<section class="section-head">
    <div>
        <h1>Admin login</h1>
        <p>Enter the admin password to open catalog management, imports, orders, and settings.</p>
    </div>
</section>

<form method="post" class="form-card admin-login-card">
    @Html.AntiForgeryToken()
    <input asp-for="ReturnUrl" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <label>
        Admin password
        <input asp-for="Password" autocomplete="current-password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </label>
    <button type="submit" class="btn btn-teal">Open admin</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
